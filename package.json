{
  "name": "letutex",
  "version": "4.0.0",
  "description": "LetuTEX — онлайн-редактор LaTeX в стиле Overleaf (Vue 3 + Express)",
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "dev": "node server/index.js",
    "dev:document-updater": "node server/documentUpdater/index.js",
    "dev:realtime": "node server/realTime/index.js",
    "dev:clsi": "node server/clsi/index.js",
    "dev:file-store": "node server/fileStore/index.js",
    "dev:git-bridge": "node server/gitBridge/index.js",
    "dev:frontend": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "ace-builds": "^1.43.6",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.0",
    "bcrypt": "^6.0.0",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.6",
    "express": "^4.21.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.1.0",
    "multer": "^2.0.2",
    "pdfjs-dist": "^5.5.207",
    "simple-git": "^3.32.3",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "jsdom": "^27.0.1",
    "postcss": "^8.4.49",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.14",
    "vite": "^6.0.0",
    "vitest": "^3.2.4"
  }
}
