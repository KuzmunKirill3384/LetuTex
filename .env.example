# Server
PORT=8000

# Data directory (user projects, uploads)
DATA_DIR=./data

# Secret key for cookie signing (change in production!)
SECRET_KEY=change-me-in-production

# Compilation
COMPILE_TIMEOUT_SECONDS=60

# File limits
MAX_FILE_SIZE_BYTES=1048576

# Projects per user limit
MAX_PROJECTS_PER_USER=50

# Docker-based compilation (optional)
USE_DOCKER_COMPILE=false
DOCKER_TEX_IMAGE=texlive/texlive:latest

# CORS origins (comma-separated, * for all)
ALLOWED_ORIGINS=*
